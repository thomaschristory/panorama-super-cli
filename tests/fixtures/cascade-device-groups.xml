<config version="11.0.0">
  <shared/>
  <devices>
    <entry name="localhost.localdomain">
      <device-group>
        <entry name="EMEA">
          <address>
            <entry name="c-m1"><ip-netmask>10.5.0.1/32</ip-netmask></entry>
            <entry name="c-m2"><ip-netmask>10.5.0.2/32</ip-netmask></entry>
          </address>
          <address-group>
            <entry name="c-grp">
              <static>
                <member>c-m1</member>
                <member>c-m2</member>
              </static>
            </entry>
          </address-group>
          <post-rulebase>
            <security>
              <rules>
                <entry name="c-rule">
                  <source><member>c-grp</member></source>
                  <destination><member>any</member></destination>
                  <service><member>any</member></service>
                </entry>
              </rules>
            </security>
          </post-rulebase>
        </entry>
      </device-group>
    </entry>
  </devices>
  <readonly>
    <devices>
      <entry name="localhost.localdomain">
        <device-group/>
      </entry>
    </devices>
  </readonly>
</config>
